# Compose-only variables (add to server ~/gateway-v2/.env alongside gateway secrets).
# Copy these lines into your deploy directory .env — do not commit real tokens.

# Image tag pulled by CI (main = dev, prod = production).
GATEWAY_IMAGE=ghcr.io/netsepio/gateway:prod
GATEWAY_CONTAINER_NAME=erebrus-gateway
GATEWAY_HOST_PORT=8080
GATEWAY_HOST=gateway.erebrus.io
TRAEFIK_CERT_RESOLVER=letsencrypt
DEPLOY_ENVIRONMENT=production

# OTLP ingest auth (telemetry server issues this).
OTEL_AUTH_TOKEN=