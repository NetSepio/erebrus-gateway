# Erebrus Gateway — essentials only (API: gateway.erebrus.io)
# Webapp: https://erebrus.io (prod) · https://dev.erebrus.io (dev)
# Copy to .env and fill in. Never commit real values.
#
# Product tunables (XP, trials, rate limits, auth text) live in platform_settings
# (migration 0009) and are editable via PATCH /api/v2/admin/settings.

# ── app ──────────────────────────────────────────────
APP_PORT=8080
GIN_MODE=release
ENVIRONMENT=production
ALLOWED_ORIGIN=https://erebrus.io,https://dev.erebrus.io,http://localhost:3000
# Reverse-proxy IPs/CIDRs for X-Forwarded-For (empty = trust none).
TRUSTED_PROXIES=

# ── identity (required in production) ────────────────
# Derives Ed25519 PASETO signer at m/44'/501'/1'/0' (separate from node wallets).
MNEMONIC=
# First admin wallet, seeded on boot when no admin exists.
ADMIN_WALLET_ADDRESS=

# ── database ─────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=erebrus
DB_PASSWORD=
DB_NAME=erebrus
DB_SSLMODE=require   # local dev: disable

# ── redis (cache only — safe to flush) ───────────────
REDIS_HOST=localhost:6379
REDIS_PASSWORD=

# ── NFT gating (optional — leave contract empty to disable) ─
NFT_GATE_CHAIN=solana
NFT_GATE_CONTRACT=
NFT_GATE_RPC_URL=

# ── optional integrations ──────────────────────────────
TELEGRAM_BOT_TOKEN=
RESEND_API_KEY=
RESEND_FROM=Erebrus <no-reply@erebrus.io>

# ── deploy / metrics (docker compose on server — see deploy/) ─
# OTEL_AUTH_TOKEN=          # OTLP bearer for otel.netsepio.com (collector only)
# GATEWAY_IMAGE=ghcr.io/netsepio/gateway:prod