# Erebrus Gateway v2 — environment template
# Copy to .env and fill in. Never commit real values.

# ── app ──────────────────────────────────────────────
APP_NAME=erebrus-gateway
APP_PORT=8080
GIN_MODE=release
ALLOWED_ORIGIN=https://erebrus.network,http://localhost:3000
VERSION=2.0.0

# ── auth ─────────────────────────────────────────────
# Gateway identity: set MNEMONIC (recommended) or an explicit PASETO_PRIVATE_KEY hex.
# When PASETO_PRIVATE_KEY is empty, the gateway derives a stable 64-byte Ed25519
# PASETO signer from MNEMONIC at m/44'/501'/1'/0' (separate from node wallet keys).
# Dev/test vector (docker-compose.v2.yml default GATEWAY_MNEMONIC):
# legal winner thank year wave sausage worth useful legal winner thank yellow
MNEMONIC=
GATEWAY_MNEMONIC=
# Ed25519 private key (hex, 64 bytes) — overrides MNEMONIC when set
PASETO_PRIVATE_KEY=
PASETO_EXPIRATION=24h
PASETO_SIGNED_BY=Erebrus
AUTH_EULA=I accept the Erebrus Terms of Service https://erebrus.network/terms.
# Email OTP lifetime (used by the optional email-linking flow below).
MAGIC_LINK_EXPIRATION=15m
# first admin user (wallet address), seeded if no admin exists
ADMIN_WALLET_ADDRESS=

# ── database (single Postgres) ───────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=erebrus
DB_PASSWORD=
DB_NAME=erebrus
DB_SSLMODE=require   # local dev: disable

# ── redis (cache only — safe to flush) ───────────────
REDIS_HOST=localhost:6379
REDIS_PASSWORD=

# ── entitlement (v2.0: trial + NFT gating, no money) ──
# General free trial: 7 days, one per user.
TRIAL_PERIOD=168h
# Leave NFT_GATE_CONTRACT empty to disable NFT gating (trial-only).
# NFT holders get 30 days directly (NFT_GATE_PERIOD), upgrading any active trial.
NFT_GATE_CHAIN=solana              # solana (Metaplex Core) | evm (future)
NFT_GATE_CONTRACT=                 # Solana: collection address | EVM: ERC-721 contract
NFT_GATE_RPC_URL=                  # Solana: DAS-capable endpoint (e.g. Helius); EVM: JSON-RPC
NFT_GATE_PERIOD=720h               # re-verify window (30d)
NFT_GATE_PLAN_ID=pro               # plan granted to NFT holders

# Organizations issue API keys (X-Api-Key) for programmatic, org-scoped
# access to /api/v2/org/* (provision VPN configs, read usage). No env needed.

# ── operator metrics (S4) ────────────────────────────
# How long per-node time-series rollups are retained before pruning.
NODE_METRICS_RETENTION=720h

# ── email (optional) ─────────────────────────────────
# Links a VERIFIED email to a wallet account (perks/ranking + recovery) via a
# 6-digit Resend OTP. Never required to use the VPN. Leave RESEND_API_KEY empty
# to disable the /api/v2/auth/email routes (they return 503 "not configured").
RESEND_API_KEY=
RESEND_FROM=Erebrus <no-reply@erebrus.network>

# ── p2p (slim libp2p bootstrap host for DHT advertise) ─
P2P_LISTEN_PORT=9001
# identity key auto-generated at secret/identity.key on first boot (gitignored)
