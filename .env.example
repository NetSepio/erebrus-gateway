# Erebrus Gateway — copy to .env (local dev) or ~/gateway/.env (prod server).
# One file feeds both the gateway binary and deploy/docker-compose.yml.
# Never commit real values.
#
# Product tunables (XP, trials, rate limits) live in platform_settings (DB).
# Gating NFT collections live in nft_gate_contracts (DB, migration 0012).

# ── app ──────────────────────────────────────────────
APP_PORT=8080
GIN_MODE=release
ENVIRONMENT=production
ALLOWED_ORIGIN=https://erebrus.io,https://dev.erebrus.io,http://localhost:3000
# Reverse-proxy IPs/CIDRs for X-Forwarded-For (empty = trust none).
TRUSTED_PROXIES=

# ── identity (required in production) ────────────────
# Derives Ed25519 PASETO signer at m/44'/501'/1'/0' (separate from node wallets).
MNEMONIC=
# First admin wallet, seeded on boot when no admin exists.
ADMIN_WALLET_ADDRESS=

# ── database ─────────────────────────────────────────
# Local dev: localhost. Prod Docker network: postgres
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=erebrus
DB_PASSWORD=
DB_NAME=erebrus
DB_SSLMODE=require   # local dev: disable

# ── redis (cache only — safe to flush) ───────────────
# Local dev: localhost:6379. Prod Docker network: redis:6379
REDIS_HOST=localhost:6379
REDIS_PASSWORD=

# ── NFT gating ───────────────────────────────────────
# Collections are seeded in nft_gate_contracts (IslandDAO + Erebrus Free Trial NFT).
# Use a DAS-capable Solana RPC in production (Helius/Triton); default is public mainnet.
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
# EVM_RPC_URL=              # future EVM collections

# ── optional integrations ──────────────────────────────
TELEGRAM_BOT_TOKEN=
RESEND_API_KEY=
RESEND_FROM=Erebrus <no-reply@erebrus.io>

# ── docker compose (server deploy dir only — ignored by gateway binary) ─
GATEWAY_IMAGE=ghcr.io/netsepio/gateway:prod
GATEWAY_CONTAINER_NAME=erebrus-gateway
GATEWAY_HOST_PORT=8080
GATEWAY_HOST=gateway.erebrus.io
TRAEFIK_CERT_RESOLVER=letsencrypt
DEPLOY_ENVIRONMENT=production
# Leave unset to skip otel-collector (gateway runs fine without telemetry).
# OTEL_AUTH_TOKEN=