# Erebrus Gateway v2 — environment template
# Copy to .env and fill in. Never commit real values.

# ── app ──────────────────────────────────────────────
APP_NAME=erebrus-gateway
APP_PORT=8080
GIN_MODE=release
ALLOWED_ORIGIN=https://erebrus.network,http://localhost:3000
VERSION=2.0.0

# ── auth ─────────────────────────────────────────────
# Ed25519 private key (hex) for PASETO signing — generate per environment
PASETO_PRIVATE_KEY=
PASETO_EXPIRATION=24h
PASETO_SIGNED_BY=Erebrus
AUTH_EULA=I accept the Erebrus Terms of Service https://erebrus.network/terms.
MAGIC_LINK_EXPIRATION=15m
GOOGLE_AUDIENCE=
# first admin user (wallet address), seeded if no admin exists
ADMIN_WALLET_ADDRESS=

# ── database (single Postgres) ───────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=erebrus
DB_PASSWORD=
DB_NAME=erebrus
DB_SSLMODE=require   # local dev: disable

# ── redis (cache only — safe to flush) ───────────────
REDIS_HOST=localhost:6379
REDIS_PASSWORD=

# ── payments: USDC on Solana + Base ──────────────────
SOLANA_RPC_URL=
SOLANA_TREASURY_ADDRESS=
BASE_RPC_URL=
BASE_TREASURY_ADDRESS=
BASE_MIN_CONFIRMATIONS=6
PAYMENT_EXPIRY_MINUTES=30

# ── email (OTP / magic links) ────────────────────────
RESEND_API_KEY=

# ── p2p (slim libp2p bootstrap host for DHT advertise) ─
P2P_LISTEN_PORT=9001
# identity key auto-generated at secret/identity.key on first boot (gitignored)
